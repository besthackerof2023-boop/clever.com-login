const TICK = [
  '🗿 Local Sigma achieves 1,000-day mewing streak — jaw now classified as a weapon',
  '📈 Scientists confirm Ohio is a simulation running on Windows XP',
  '💎 Aura levels reaching critical mass in the suburbs',
