/* ── PARTICLES ── */
.particle{position:fixed;pointer-events:none;z-index:1000;font-size:1.5rem;user-select:none;animation:particleFly 1.3s ease-out forwards}
@keyframes particleFly{0%{opacity:1;transform:translate(0,0) scale(1.1)}100%{opacity:0;transform:translate(var(--dx),var(--dy)) scale(.4)}}

/* ── HIT TEXT ── */
.hit{position:fixed;pointer-events:none;z-index:1000;user-select:none;font-family:'Bebas Neue',cursive;font-size:1.8rem;animation:hitFloat .9s ease-out forwards;white-space:nowrap}
@keyframes hitFloat{0%{opacity:1;transform:translateY(0) scale(1.1)}55%{opacity:1;transform:translateY(-42px) scale(1.2)}100%{opacity:0;transform:translateY(-88px) scale(.7)}}

/* ── SHAKE ── */
.shaking{animation:bigShake .5s ease-in-out}
@keyframes bigShake{0%,100%{transform:translate(0,0)}15%{transform:translate(-4px,-3px) rotate(-.6deg)}30%{transform:translate(4px,3px) rotate(.6deg)}45%{transform:translate(-3px,4px) rotate(-.4deg)}60%{transform:translate(3px,-4px) rotate(.4deg)}75%{transform:translate(-4px,2px) rotate(-.5deg)}90%{transform:translate(2px,-3px) rotate(.3deg)}}

/* ── SHOP ── */
@keyframes shopGlow{0%,100%{box-shadow:0 0 4px rgba(255,215,0,.2)}50%{box-shadow:0 0 18px rgba(255,215,0,.75),0 0 36px rgba(255,140,0,.35)}}
.shop-glow{animation:shopGlow 2s ease-in-out infinite}
.shop-card{border-radius:12px;padding:10px 12px;border:1px solid;transition:transform .15s,opacity .2s;cursor:pointer}
.shop-card:hover{transform:translateY(-2px) scale(1.02)}

/* ── DIM TABS ── */
.dim-tab{border-radius:8px;padding:5px 10px;font-family:'Bebas Neue',cursive;font-size:.8rem;letter-spacing:1px;cursor:pointer;transition:all .15s;border:1px solid;white-space:nowrap}
.dim-tab:hover{transform:translateY(-1px)}
.dim-tab.locked{opacity:.3;cursor:not-allowed}

/* ── OVERLAY ── */
.overlay{position:fixed;inset:0;z-index:2000;background:rgba(0,0,0,.93);display:flex;align-items:center;justify-content:center;backdrop-filter:blur(14px);animation:fadeIn .3s ease}
.overlay-box{animation:popIn .35s cubic-bezier(.34,1.56,.64,1)}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes popIn{from{opacity:0;transform:scale(.75) translateY(40px)}to{opacity:1;transform:scale(1) translateY(0)}}

/* ── PRES BTN ── */
@keyframes pressPulse{0%,100%{box-shadow:0 0 30px #ffd70077,0 0 60px #ff8c0033}50%{box-shadow:0 0 55px #ffd700cc,0 0 110px #ff8c0077}}
.pres-btn{animation:pressPulse 1.2s ease-in-out infinite;border:none;cursor:pointer;transition:transform .12s}
.pres-btn:hover{transform:scale(1.06)}
.pres-btn:active{transform:scale(.93)}

/* ── MEWING BADGE ── */
