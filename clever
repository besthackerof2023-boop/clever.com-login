/* ── DEEP FRY ── */
.df0{filter:none}
.df1{filter:brightness(1.15) saturate(1.8) drop-shadow(0 0 8px #ffd700)}
.df2{filter:brightness(1.3) saturate(3) contrast(1.3) drop-shadow(0 0 16px #ff8c00)}
