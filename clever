const DF_LABELS = ['Normal','Glowing','Saturated','Corrupted','Deep Fried','Ultra Fried','🔥 MAX BRAINROT'];

/* ── UTILS ── */
const fmt = n => {
  if(n>=1e24)return(n/1e24).toFixed(2)+'Sp';
  if(n>=1e21)return(n/1e21).toFixed(2)+'Sx';
  if(n>=1e18)return(n/1e18).toFixed(2)+'Qi';
  if(n>=1e15)return(n/1e15).toFixed(2)+'Qa';
  if(n>=1e12)return(n/1e12).toFixed(2)+'T';
  if(n>=1e9) return(n/1e9).toFixed(2)+'B';
  if(n>=1e6) return(n/1e6).toFixed(2)+'M';
  if(n>=1e3) return(n/1e3).toFixed(2)+'K';
  return Math.floor(n).toString();
};
const upgCost=(u,o)=>Math.floor(u.baseCost*Math.pow(1.15,o));
const upgCps=(u,o)=>u.baseCps*o;
const getDf=t=>{for(let i=DF_MILESTONES.length-1;i>=0;i--)if(t>=DF_MILESTONES[i])return i+1;return 0};
const save=s=>{try{localStorage.setItem('sc2025v2',JSON.stringify(s))}catch{}};
const load=()=>{
  try{
    const s=localStorage.getItem('sc2025v2');
    if(s)return JSON.parse(s);
    const v1=localStorage.getItem('sc2025');
    if(v1){
      const d=JSON.parse(v1);
      const owned=Array(20).fill(0);
      if(Array.isArray(d.owned))d.owned.forEach((v,i)=>{if(i<4)owned[i]=v;});
      return {...d,owned};
    }
    return null;
  }catch{return null;}
};

/* ── STARS ── */
const STARS=Array.from({length:90},(_,i)=>({id:i,left:Math.random()*100,size:Math.random()*3+.5,dur:Math.random()*4+2,del:Math.random()*7}));
const Starfield=()=>(
  <div className="starfield">
    {STARS.map(s=><div key={s.id} className="star" style={{left:`${s.left}%`,width:s.size,height:s.size,animationDuration:`${s.dur}s`,animationDelay:`${s.del}s`}}/>)}
  </div>
);

/* ── STONE ── */
const SigmaStone=({mewing,df,dimId,onClick,stoneRef})=>{
  const [sq,setSq]=useState(false);
  const fire=e=>{setSq(true);setTimeout(()=>setSq(false),220);onClick(e);};
