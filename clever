@keyframes cyanRing{0%,100%{box-shadow:0 0 35px #00ffffaa,0 0 75px #0088ffaa}50%{box-shadow:0 0 65px #ffffffcc,0 0 130px #00aaffcc}}
@keyframes purpleRing{0%,100%{box-shadow:0 0 30px #a855f799,0 0 65px #7c3aed66}50%{box-shadow:0 0 55px #a855f7cc,0 0 110px #7c3aed99}}
@keyframes greenRing{0%,100%{box-shadow:0 0 30px #00ff8899,0 0 65px #00cc6666}50%{box-shadow:0 0 55px #00ff88cc,0 0 110px #00cc6699}}
@keyframes redRing{0%,100%{box-shadow:0 0 30px #f43f5e99,0 0 65px #e11d4866}50%{box-shadow:0 0 55px #f43f5ecc,0 0 110px #e11d4899}}
@keyframes whiteRing{0%,100%{box-shadow:0 0 30px #ffffff77,0 0 65px #aaaaaa44}50%{box-shadow:0 0 55px #ffffffbb,0 0 110px #aaaaaa66}}
.ring-gold{animation:goldRing 2s ease-in-out infinite}
.ring-cyan{animation:cyanRing .45s ease-in-out infinite}
.ring-purple{animation:purpleRing 1.5s ease-in-out infinite}
.ring-green{animation:greenRing 1.5s ease-in-out infinite}
.ring-red{animation:redRing 1.2s ease-in-out infinite}
.ring-white{animation:whiteRing 2s ease-in-out infinite}

/* ── SQUISH ── */
.squish{animation:squish .2s ease-out!important;transform-origin:center}
@keyframes squish{0%{transform:scale(1)}30%{transform:scale(.84) rotate(-2deg)}65%{transform:scale(1.07) rotate(1deg)}100%{transform:scale(1) rotate(0)}}

/* ── LASER ── */
@keyframes laserPulse{from{opacity:.6;transform:scaleX(.8)}to{opacity:1;transform:scaleX(1.2)}}
