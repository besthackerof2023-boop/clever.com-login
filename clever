.df5{filter:brightness(2.2) saturate(14) contrast(3.2) hue-rotate(35deg) drop-shadow(0 0 44px #ff00ff);animation:vibrate .04s infinite}
@keyframes vibrate{0%,100%{transform:translate(0,0)}20%{transform:translate(-2px,2px)}40%{transform:translate(2px,-2px)}60%{transform:translate(-2px,-1px)}80%{transform:translate(2px,1px)}}

/* ── RINGS ── */
