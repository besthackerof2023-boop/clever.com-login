/* ── STARFIELD ── */
.starfield{position:fixed;inset:0;pointer-events:none;z-index:0;overflow:hidden}
.star{position:absolute;background:#fff;border-radius:50%;animation:starFall linear infinite}
@keyframes starFall{from{transform:translateY(-10px);opacity:.9}to{transform:translateY(105vh);opacity:0}}

/* ── TICKER ── */
.ticker-rail{overflow:hidden;white-space:nowrap}
.ticker-inner{display:inline-block;animation:tickerScroll 60s linear infinite}
